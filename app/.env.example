# Plantilla de variables de entorno.
# Copiar a .env y reemplazar valores antes de levantar en producción.

# Credenciales de MongoDB
MONGO_USER=admin
MONGO_PASSWORD=cambiar_en_produccion

# Secreto JWT (mínimo 32 bytes aleatorios)
# Generar con: openssl rand -base64 48
JWT_SECRET=cambiar_en_produccion_minimo_32_bytes_aleatorios_xxxxxxxxxxxxxxxxxxxxxx

# Zona horaria
TZ=America/Bogota
